POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://lms:change-me@db:5432/lms

JWT_SECRET=generate-a-long-random-secret
UPLOAD_DIR=/app/uploads

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3001

# Keep the real Brevo key only in .env or your production secret manager.
BREVO_API_KEY=
# Optional: if omitted, the backend uses the first active sender in Brevo.
BREVO_SENDER_ID=
PASSWORD_RESET_EXPIRES_MINUTES=30
PASSWORD_RESET_MAX_PER_HOUR=3
